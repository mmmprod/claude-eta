{
  "name": "claude-eta",
  "version": "0.3.4",
  "description": "AI-powered task duration tracker and predictor for Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "test": "SKIP_INTEGRATION=1 npm run build && SKIP_INTEGRATION=1 node --test --test-concurrency=1",
    "test:integration": "npm run build && node --test tests/supabase-integration.test.js",
    "lint": "eslint src --max-warnings 0",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.js\" \"*.{js,json,md,yml,yaml}\" \".github/workflows/*.yml\"",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.js'",
    "prepare": "husky"
  },
  "keywords": [
    "claude-code",
    "plugin",
    "eta",
    "time-tracking",
    "estimation"
  ],
  "author": "mmmprod",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "*.{js,mjs,cjs,json,md,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  }
}
