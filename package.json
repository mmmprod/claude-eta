{
  "name": "claude-eta",
  "version": "0.3.1",
  "description": "AI-powered task duration tracker and predictor for Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "npm run build && node --test",
    "lint": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.js'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.js'"
  },
  "keywords": [
    "claude-code",
    "plugin",
    "eta",
    "time-tracking",
    "estimation"
  ],
  "author": "mmmprod",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "prettier": "^3.8.1",
    "typescript": "^5.0.0"
  }
}
